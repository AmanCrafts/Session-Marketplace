# =========================================================================
# Sessions Marketplace — Backend environment configuration
# =========================================================================
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# The backend reads these via `python-dotenv` at startup.
# =========================================================================

# ---------- Django ---------- #
DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ---------- Database ---------- #
# DATABASE_USE_POSTGRES toggles between PostgreSQL and SQLite.
# In Docker compose this is set to true and the values below match
# the `db` service.
DATABASE_USE_POSTGRES=true
POSTGRES_DB=sessions
POSTGRES_USER=sessions
POSTGRES_PASSWORD=sessions
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# ---------- DRF ---------- #
REST_FRAMEWORK_PAGE_SIZE=20

# ---------- CORS ---------- #
# Comma-separated list of origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Supabase ---------- #
# The Supabase project URL (e.g. https://abcd1234.supabase.co).
SUPABASE_URL=
# The Supabase JWT secret (Project Settings -> API -> JWT Secret).
SUPABASE_JWT_SECRET=
# Audience claim expected on the JWT.
SUPABASE_JWT_AUDIENCE=authenticated
# Allowed clock skew between Supabase and the backend.
SUPABASE_JWT_LEEWAY_SECONDS=30
# Tests-only escape hatch: skip signature verification. Never enable in prod.
SUPABASE_JWT_DISABLE_VERIFICATION=false

# ---------- Logging ---------- #
LOG_LEVEL=INFO